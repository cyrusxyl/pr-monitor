# GitHub PR Monitor Configuration
# Copy this file to ~/.config/pr-monitor/config.yaml and fill in your details

general:
  # How often to refresh PR data (in seconds). Default: 300 (5 minutes)
  refresh_interval_seconds: 300
  # Theme for the TUI (optional)
  # Available themes: https://textual.textualize.io/guide/design/#themes
  theme: "monokai"

# accounts — credentials + optional repo scope
# repos: []          → query all repos the token has access to
# repos: [org/repo]  → restrict queries to those repos
accounts:
  - id: "personal"
    label: "GitHub Public"
    api_base: "https://api.github.com"
    token_env_var: "GH_PUBLIC_TOKEN"   # export GH_PUBLIC_TOKEN="ghp_xxxx..."
    repos: []

  - id: "work"
    label: "Work"
    # For GitHub Enterprise: https://github.your-company.com/api/v3
    api_base: "https://github.your-company.com/api/v3"
    token_env_var: "GH_WORK_TOKEN"     # export GH_WORK_TOKEN="ghp_yyyy..."
    repos:
      - "organization/repo-name-1"
      - "organization/repo-name-2"

# boxes — display panels; each runs one query against one or more accounts
# accounts: [id1, id2]   → run against listed accounts only
# accounts: omitted       → run against ALL accounts
# closed_since_days: N    → appends "closed:>YYYY-MM-DD" to the query automatically
boxes:
  - label: "Review Requested"
    query: "is:pr is:open review-requested:@me"
    accounts: ["personal", "work"]

  - label: "My PRs"
    query: "is:pr is:open author:@me"
    accounts: ["personal", "work"]

  - label: "Recently Closed"
    query: "is:pr is:closed author:@me"
    closed_since_days: 14
    accounts: ["personal", "work"]

# Common query patterns:
#   review-requested:@me  — PRs where you're a requested reviewer
#   author:@me            — PRs you created
#   assignee:@me          — PRs assigned to you
#   mentions:@me          — PRs that mention you
#   label:bug             — PRs with specific labels
#   review:approved       — PRs that have been approved
#   is:draft              — draft PRs only
#
# Full syntax: https://docs.github.com/en/search-github/searching-on-github/searching-issues-and-pull-requests
